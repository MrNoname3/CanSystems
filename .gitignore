# Build output
.pio

# LittleFS image source - transient, generated by ota/otaUpdate.py provisioning
data/

# IDE
.vscode/.browse.c_cpp.db*
.vscode/c_cpp_properties.json
.vscode/launch.json
.vscode/ipch

# Logs & monitor
platformio-device-monitor-*
logs/device-monitor-*

# Scripts
**/__pycache__/

# Python tool caches (pytest/ruff drop a self-ignoring .gitignore inside too; listed
# here explicitly so it does not depend on the tool version writing it).
.pytest_cache/
.ruff_cache/

# Python tooling venv (project-root, from requirements-dev.txt); the bare pattern also
# catches any stray ota/.venv from before the consolidation.
.venv/

# OTA
ota/secrets.yaml
ota/files/**/*.crt
