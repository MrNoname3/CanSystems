# Build output
.pio

# IDE
.vscode/.browse.c_cpp.db*
.vscode/c_cpp_properties.json
.vscode/launch.json
.vscode/ipch

# Logs & monitor
platformio-device-monitor-*
logs/device-monitor-*

# Notes
notes.txt

# Data
audio/*
!audio/.gitkeep
data/*.bin

# Scripts
**/__pycache__/

# Python tooling venv (project-root, from requirements-dev.txt); the bare pattern also
# catches any stray ota/.venv from before the consolidation.
.venv/

# OTA
ota/config.yaml
ota/files/**/*.crt
ota/files/**/*.bak
ota/files/**/server.json
ota/files/**/wifi.json

# Firmware backups (raw flash dumps)
backups/*.bin
