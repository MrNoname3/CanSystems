# EditorConfig: editor-agnostic enforcement of the project's whitespace rules,
# mirroring .vscode/settings.json so non-VS-Code editors behave the same.
# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
insert_final_newline = true

# Python follows PEP 8 (4-space), like the [python] override in .vscode/settings.json.
[*.py]
indent_size = 4
